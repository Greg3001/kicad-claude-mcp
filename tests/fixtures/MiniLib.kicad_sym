(kicad_symbol_lib
	(version 20251024)
	(generator "test")
	(generator_version "10.0")
	(symbol "Resistor"
		(property "Reference" "R" (at 0 0 0))
		(property "Value" "Resistor" (at 0 0 0))
		(property "Footprint" "Resistor_SMD:R_0603_1608Metric" (at 0 0 0))
		(property "Datasheet" "~" (at 0 0 0))
		(property "Description" "Generic resistor" (at 0 0 0))
		(property "ki_keywords" "R res resistor" (at 0 0 0))
		(symbol "Resistor_0_1"
			(pin passive line
				(at 0 2.54 270)
				(length 1.27)
				(name "~" (effects (font (size 1 1))))
				(number "1" (effects (font (size 1 1))))
			)
			(pin passive line
				(at 0 -2.54 90)
				(length 1.27)
				(name "~" (effects (font (size 1 1))))
				(number "2" (effects (font (size 1 1))))
			)
		)
	)
	(symbol "R_Small"
		(extends "Resistor")
		(property "Reference" "R" (at 0 0 0))
		(property "Value" "R_Small" (at 0 0 0))
		(property "Description" "Small resistor symbol" (at 0 0 0))
		(property "ki_keywords" "R res resistor small" (at 0 0 0))
	)
	(symbol "ESP32_Demo"
		(property "Reference" "U" (at 0 0 0))
		(property "Value" "ESP32-S3-DEMO" (at 0 0 0))
		(property "Footprint" "" (at 0 0 0))
		(property "Datasheet" "https://example.com/esp32.pdf" (at 0 0 0))
		(property "Description" "Made-up ESP32-S3 module for tests" (at 0 0 0))
		(property "ki_keywords" "wifi bt esp32 microcontroller" (at 0 0 0))
		(symbol "ESP32_Demo_1_1"
			(pin power_in line
				(at 0 0 0)
				(length 1)
				(name "VCC" (effects (font (size 1 1))))
				(number "1" (effects (font (size 1 1))))
			)
			(pin power_in line
				(at 0 0 0)
				(length 1)
				(name "GND" (effects (font (size 1 1))))
				(number "2" (effects (font (size 1 1))))
			)
			(pin bidirectional line
				(at 0 0 0)
				(length 1)
				(name "GPIO0" (effects (font (size 1 1))))
				(number "3" (effects (font (size 1 1))))
			)
		)
	)
)
