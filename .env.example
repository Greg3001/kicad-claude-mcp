# Copy to .env and fill in. Do NOT commit .env.

# DigiKey developer credentials — https://developer.digikey.com
# Used in Phase 4 (sourcing). OAuth2 client credentials.
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=

# Mouser API key — https://www.mouser.com/api-hub/
# Used in Phase 4 (sourcing).
MOUSER_API_KEY=

# Override KiCAD library auto-detection if needed.
# Leave empty to auto-detect from OS.
KICAD_LIBRARY_PATH=

# Path to freerouting.jar — used in Phase 6 (autorouting).
# Download from https://github.com/freerouting/freerouting/releases.
# Freerouting 2.2.x requires Java 25; 2.0.x / 2.1.x run on Java 21+.
# If the file lives at <repo>/third_party/freerouting.jar this can be empty.
FREEROUTING_JAR=

# Override KiCAD's bundled Python (used to call pcbnew for DSN/SES interchange,
# since kicad-cli v10 doesn't expose those). On macOS auto-detected at:
# /Applications/KiCad/KiCad.app/Contents/Frameworks/Python.framework/Versions/Current/bin/python3
KICAD_PYTHON=

# Override the `java` binary if not on PATH or you want a specific JRE.
JAVA_BIN=
