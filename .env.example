# Copy to .env and fill in. Do NOT commit .env.

# DigiKey developer credentials — https://developer.digikey.com
# Used in Phase 4 (sourcing). OAuth2 client credentials.
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=

# Mouser API key — https://www.mouser.com/api-hub/
# Used in Phase 4 (sourcing).
MOUSER_API_KEY=

# Override KiCAD library auto-detection if needed.
# Leave empty to auto-detect from OS.
KICAD_LIBRARY_PATH=

# Path to freerouting.jar — used in Phase 6 (autorouting).
# Download from https://github.com/freerouting/freerouting/releases
FREEROUTING_JAR=
